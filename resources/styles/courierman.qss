QToolTip {
    background: #111827;
    color: #ffffff;
    border: 0;
    padding: 6px;
}

QScrollBar:vertical {
    width: 10px;
    margin: 0;
}

QScrollBar:horizontal {
    height: 10px;
    margin: 0;
}

QScrollBar::handle {
    border-radius: 5px;
    min-height: 24px;
}

QCheckBox,
QLabel {
    background: transparent;
}
